# PlayBox — Environment variables template (committed, no secrets)
# Copy this file to .env and adjust values for your local setup.

# --- Quiz game database ---
# During development: SQLite (no PostgreSQL required).
# For production: switch to postgresql://playbox:playbox@localhost:5432/playbox_quiz
# TODO: post-dev — switch back to PostgreSQL for go-live.
PLAYBOX_DATABASE_URL=sqlite:///./data/quiz.db

# --- SQLite (Imposter / Piccolo) ---
PLAYBOX_SQLITE_URL=sqlite:///./data/local.db

# --- App ---
PLAYBOX_DEBUG=false

# --- CORS ---
PLAYBOX_CORS_ORIGINS=["http://localhost:5173"]

# --- Media ---
PLAYBOX_MEDIA_DIR=./media
PLAYBOX_MAX_MEDIA_SIZE_MB=50

